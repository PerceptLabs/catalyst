{
  "name": "@aspect/catalyst-engine-deno",
  "version": "0.0.1",
  "description": "Deno-in-WASM engine for Catalyst — V8 jitless runtime compiled to WebAssembly",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./loaders": {
      "import": "./src/loaders/index.ts",
      "types": "./src/loaders/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/loaders/index.ts --format esm --dts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
