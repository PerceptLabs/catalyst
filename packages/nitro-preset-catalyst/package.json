{
  "name": "@aspect/nitro-preset-catalyst",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./entry": "./dist/entry.js",
    "./storage-driver": "./dist/storage-driver.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/entry.ts src/storage-driver.ts --format esm --dts"
  },
  "peerDependencies": {
    "nitropack": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "nitropack": {
      "optional": true
    }
  },
  "dependencies": {
    "@aspect/catalyst-workers": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
